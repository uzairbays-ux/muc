{% liquid
  assign s = section.settings
  assign gap = s.gap | default: 16
  assign bg_color = s.background_color
%}

<div
  class="section section--{{ s.section_width }} spacing-style"
  style="{% render 'spacing-style', settings: s %}{% if bg_color != blank %} background-color: {{ bg_color }};{% endif %}"
  data-testid="promo-grid-{{ section.id }}"
>
  <div class="promo-grid" style="--pg-gap: {{ gap }}px;">
    {%- for block in section.blocks -%}
      {%- assign b = block.settings -%}
      <div class="promo-grid__card" {{ block.shopify_attributes }}>
        {%- if b.link != blank -%}
          <a href="{{ b.link }}" class="promo-grid__link" {% if b.open_new_tab %}target="_blank" rel="noopener"{% endif %}>
        {%- endif -%}

          <div class="promo-grid__banner">
            {%- if b.image != blank -%}
              {{
                b.image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  widths: '400,600,800,1000,1200',
                  sizes: '(max-width: 749px) 100vw, 50vw',
                  class: 'promo-grid__image',
                  alt: b.image.alt | default: b.heading | default: ''
              }}
            {%- else -%}
              <div class="promo-grid__placeholder">
                {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>

          <div class="promo-grid__content">
            {%- if b.heading != blank -%}
              <h3 class="promo-grid__heading">{{ b.heading }}</h3>
            {%- endif -%}
            {%- if b.subheading != blank -%}
              <p class="promo-grid__subheading">{{ b.subheading }}</p>
            {%- endif -%}
          </div>

        {%- if b.link != blank -%}
          </a>
        {%- endif -%}
      </div>
    {%- else -%}
      {%- for i in (1..4) -%}
        <div class="promo-grid__card">
          <div class="promo-grid__banner">
            <div class="promo-grid__placeholder">
              {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          </div>
          <div class="promo-grid__content">
            <h3 class="promo-grid__heading">Heading {{ i }}</h3>
            <p class="promo-grid__subheading">Description text goes here</p>
          </div>
        </div>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .promo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--pg-gap, 16px);
  }

  .promo-grid__card {
    position: relative;
    border-radius: var(--style-border-radius-card, 12px);
    overflow: hidden;
    background-color: #f8f8f8;
  }

  .promo-grid__link {
    display: flex;
    flex-direction: row;
    text-decoration: none;
    color: inherit;
    height: 100%;
    transition: transform 200ms ease;
  }

  .promo-grid__link:hover {
    transform: scale(1.01);
  }

  .promo-grid__card:not(:has(.promo-grid__link)) {
    display: flex;
    flex-direction: row;
  }

  /* Content (text side) */
  .promo-grid__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 24px;
    flex: 0 0 40%;
    max-width: 40%;
    background-color: rgba(255, 255, 255, 0.92);
    z-index: 1;
  }

  .promo-grid__heading {
    margin: 0;
    font-family: var(--font-heading--family);
    font-size: 20px;
    font-weight: 700;
    line-height: 1.2;
    color: rgb(var(--color-foreground-heading, 0, 0, 0));
  }

  .promo-grid__subheading {
    margin: 8px 0 0;
    font-size: 14px;
    line-height: 1.4;
    color: rgb(var(--color-foreground, 0, 0, 0));
    opacity: 0.75;
  }

  /* Banner (image side) */
  .promo-grid__banner {
    flex: 1;
    min-height: 180px;
    position: relative;
    overflow: hidden;
  }

  .promo-grid__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .promo-grid__placeholder {
    width: 100%;
    height: 100%;
    min-height: 180px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #eee;
  }

  .promo-grid__placeholder .placeholder-svg {
    width: 40%;
    height: 40%;
    opacity: 0.3;
  }

  /* Mobile: portrait layout — banner top, text below */
  @media screen and (max-width: 749px) {
    .promo-grid {
      grid-template-columns: 1fr;
    }

    .promo-grid__link,
    .promo-grid__card:not(:has(.promo-grid__link)) {
      flex-direction: column;
    }

    .promo-grid__content {
      flex: none;
      max-width: 100%;
      padding: 16px 20px;
    }

    .promo-grid__banner {
      min-height: 160px;
    }

    .promo-grid__heading {
      font-size: 18px;
    }

    .promo-grid__subheading {
      font-size: 13px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Promo grid",
  "tag": "section",
  "class": "section-promo-grid",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between cards",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background color"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "promo_card",
      "name": "Promo card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Banner image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Unbox the joy of giving"
        },
        {
          "type": "textarea",
          "id": "subheading",
          "label": "Subheading",
          "default": "Discover perfect gifts for every occasion"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Open link in new tab",
          "default": false
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Promo grid",
      "category": "Banners",
      "blocks": [
        { "type": "promo_card", "settings": { "heading": "Unbox the joy of giving", "subheading": "Discover perfect gifts for every occasion" } },
        { "type": "promo_card", "settings": { "heading": "Elevate your style", "subheading": "Explore the right tools for your daily routine" } },
        { "type": "promo_card", "settings": { "heading": "Find your signature scent", "subheading": "Premium fragrances for every mood" } },
        { "type": "promo_card", "settings": { "heading": "Korean Beauty Store", "subheading": "Glow brighter with K-beauty picks" } }
      ]
    }
  ]
}
{% endschema %}
