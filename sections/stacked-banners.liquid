{% liquid
  assign s = section.settings
  assign gap = s.gap | default: 0
  assign bg_color = s.background_color | default: 'transparent'
%}

<div class="section-background color-{{ s.color_scheme }}"></div>
<div
  class="section section--full-width color-{{ s.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: s %}"
  data-testid="stacked-banners-{{ section.id }}"
>
  <div class="stacked-banners" style="--sb-gap: {{ gap }}px; background-color: {{ bg_color }};">
    {%- for block in section.blocks -%}
      {%- assign b = block.settings -%}
      <div class="stacked-banners__item" {{ block.shopify_attributes }}>
        {%- if b.link != blank -%}
          <a href="{{ b.link }}" class="stacked-banners__link" {% if b.open_new_tab %}target="_blank" rel="noopener"{% endif %}>
        {%- endif -%}

          <picture class="stacked-banners__picture">
            {%- if b.mobile_image != blank -%}
              <source
                media="(max-width: 749px)"
                srcset="{{ b.mobile_image | image_url: width: 750 }} 750w, {{ b.mobile_image | image_url: width: 1080 }} 1080w"
                sizes="100vw"
                width="{{ b.mobile_image.width }}"
                height="{{ b.mobile_image.height }}"
              >
            {%- endif -%}
            {%- if b.desktop_image != blank -%}
              {%- liquid
                if forloop.first
                  assign img_loading = 'eager'
                else
                  assign img_loading = 'lazy'
                endif
              -%}
              {{
                b.desktop_image
                | image_url: width: 2400
                | image_tag:
                  loading: img_loading,
                  widths: '750,1100,1500,1800,2200,2400',
                  sizes: '100vw',
                  class: 'stacked-banners__image',
                  alt: b.desktop_image.alt | default: ''
              }}
            {%- else -%}
              <div class="stacked-banners__placeholder">
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </picture>

        {%- if b.link != blank -%}
          </a>
        {%- endif -%}
      </div>
    {%- else -%}
      {%- for i in (1..3) -%}
        <div class="stacked-banners__item">
          <div class="stacked-banners__placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        </div>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .stacked-banners {
    display: flex;
    flex-direction: column;
    gap: var(--sb-gap, 0px);
    width: 100%;
  }

  .stacked-banners__item {
    position: relative;
    width: 100%;
  }

  .stacked-banners__link {
    display: block;
    width: 100%;
    text-decoration: none;
    color: inherit;
  }

  .stacked-banners__picture {
    display: block;
    width: 100%;
  }

  .stacked-banners__image {
    display: block;
    width: 100%;
    height: auto;
  }

  .stacked-banners__placeholder {
    width: 100%;
    aspect-ratio: 21 / 9;
    background-color: rgb(var(--color-foreground) / 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stacked-banners__placeholder .placeholder-svg {
    width: 40%;
    height: 40%;
    opacity: 0.3;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Stacked banners",
  "tag": "section",
  "class": "section-stacked-banners",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between images",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "info": "Visible in the gap between stacked images and behind the section.",
      "default": "#ffffff"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "settings": [
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Desktop image",
          "info": "Full-width banner. Height adapts to image aspect ratio."
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image",
          "info": "Optional. Different image for screens under 750px."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Makes the banner clickable."
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Open link in new tab",
          "default": false
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Stacked banners",
      "category": "Banners",
      "blocks": [
        { "type": "banner" },
        { "type": "banner" },
        { "type": "banner" }
      ]
    }
  ]
}
{% endschema %}
