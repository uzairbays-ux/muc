{% liquid
  assign s = section.settings
  assign embed = s.embed_url
  assign status = s.status | default: 'live'
%}

<div
  class="section section--{{ s.section_width }} color-{{ s.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: s %}"
  data-testid="live-stream-{{ section.id }}"
>
  <div class="live-stream">
    <div class="live-stream__header">
      {%- if status != blank -%}
        <span class="live-stream__badge live-stream__badge--{{ status }}">
          {%- if status == 'live' -%}● Live now{%- elsif status == 'upcoming' -%}● Upcoming{%- else -%}● Ended{%- endif -%}
        </span>
      {%- endif -%}
      {%- if s.heading != blank -%}
        <h1 class="live-stream__heading">{{ s.heading }}</h1>
      {%- endif -%}
      {%- if s.subheading != blank -%}
        <p class="live-stream__subheading">{{ s.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="live-stream__player">
      {%- if embed != blank -%}
        <div class="live-stream__embed">
          <iframe
            src="{{ embed }}"
            title="{{ s.heading | default: 'Livestream' | escape }}"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      {%- else -%}
        <div class="live-stream__placeholder">
          <p>Paste a YouTube Live, Twitch, Vimeo, or other embed URL in the section settings.</p>
        </div>
      {%- endif -%}
    </div>

    {%- if s.description != blank -%}
      <div class="live-stream__description rte">{{ s.description }}</div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="live-stream__products">
        {%- if s.products_heading != blank -%}
          <h2 class="live-stream__products-heading">{{ s.products_heading }}</h2>
        {%- endif -%}
        <div class="live-stream__products-grid">
          {%- for block in section.blocks -%}
            {%- assign p = block.settings.product -%}
            {%- if p != blank -%}
              <a href="{{ p.url }}" class="live-stream__product" {{ block.shopify_attributes }}>
                <div class="live-stream__product-image">
                  {%- if p.featured_image != blank -%}
                    {{ p.featured_image | image_url: width: 400 | image_tag: loading: 'lazy', widths: '200,300,400', sizes: '(max-width: 749px) 40vw, 200px', alt: p.title }}
                  {%- endif -%}
                </div>
                <div class="live-stream__product-info">
                  <span class="live-stream__product-title">{{ p.title | truncate: 60 }}</span>
                  <span class="live-stream__product-price">{{ p.price | money }}</span>
                </div>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .live-stream {
    max-width: 1024px;
    margin: 0 auto;
    padding-inline: var(--gap-md, 16px);
  }

  .live-stream__header { text-align: center; margin-bottom: 20px; }

  .live-stream__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 12px;
  }

  .live-stream__badge--live { background-color: #ff3b3b; color: #fff; }
  .live-stream__badge--upcoming { background-color: #f7b500; color: #000; }
  .live-stream__badge--ended { background-color: #888; color: #fff; }

  .live-stream__heading {
    margin: 0 0 6px;
    font-family: var(--font-heading--family);
    font-size: 32px;
    line-height: 1.15;
    color: rgb(var(--color-foreground-heading, 0 0 0));
  }

  .live-stream__subheading {
    margin: 0;
    font-size: 15px;
    color: rgb(var(--color-foreground, 0 0 0) / 0.7);
  }

  .live-stream__player { margin: 16px 0; }

  .live-stream__embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    background-color: #000;
  }

  .live-stream__embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .live-stream__placeholder {
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgb(var(--color-foreground, 0 0 0) / 0.05);
    border-radius: 12px;
    padding: 24px;
    text-align: center;
    color: rgb(var(--color-foreground, 0 0 0) / 0.6);
  }

  .live-stream__description { margin: 20px 0; font-size: 15px; line-height: 1.6; }

  .live-stream__products { margin-top: 32px; }

  .live-stream__products-heading {
    margin: 0 0 16px;
    font-family: var(--font-heading--family);
    font-size: 20px;
    color: rgb(var(--color-foreground-heading, 0 0 0));
  }

  .live-stream__products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }

  .live-stream__product {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    border: 1px solid rgb(var(--color-foreground, 0 0 0) / 0.08);
    border-radius: 10px;
    overflow: hidden;
    transition: transform 200ms ease;
  }

  .live-stream__product:hover { transform: translateY(-2px); }

  .live-stream__product-image {
    aspect-ratio: 1 / 1;
    background-color: rgb(var(--color-foreground, 0 0 0) / 0.04);
  }

  .live-stream__product-image img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .live-stream__product-info { padding: 10px 12px; display: flex; flex-direction: column; gap: 4px; }

  .live-stream__product-title { font-size: 13px; line-height: 1.3; font-weight: 500; }
  .live-stream__product-price { font-size: 13px; font-weight: 700; }

  @media screen and (max-width: 749px) {
    .live-stream__heading { font-size: 22px; }
    .live-stream__products-grid { grid-template-columns: repeat(2, 1fr); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Live stream",
  "tag": "section",
  "class": "section-live-stream",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Live shopping" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Join us live and shop the looks as we reveal them." },
    {
      "type": "select",
      "id": "status",
      "label": "Status badge",
      "options": [
        { "value": "live", "label": "Live now" },
        { "value": "upcoming", "label": "Upcoming" },
        { "value": "ended", "label": "Ended" },
        { "value": "", "label": "No badge" }
      ],
      "default": "live"
    },
    { "type": "header", "content": "Video embed" },
    { "type": "url", "id": "embed_url", "label": "Embed URL", "info": "Use the iframe /embed URL from YouTube Live, Twitch, Vimeo, etc." },
    { "type": "richtext", "id": "description", "label": "Description" },
    { "type": "header", "content": "Featured products" },
    { "type": "text", "id": "products_heading", "label": "Products heading", "default": "Featured in this stream" },
    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding-block-start", "label": "Top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 32 },
    { "type": "range", "id": "padding-block-end", "label": "Bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 64 }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    { "name": "Live stream", "category": "Video" }
  ]
}
{% endschema %}
