{% liquid
  assign s = section.settings
  assign tracker_url = s.tracker_url | default: 'https://track.aftership.com/'
  assign method = s.method | default: 'redirect'
  assign use_iframe = s.use_iframe
  assign iframe_base = s.iframe_base_url | default: 'https://makeupcity.ginkgoretail.net/ordertracking/'
  assign iframe_height = s.iframe_height | default: 800
  assign require_email = s.require_email
%}

<div
  class="section section--{{ s.section_width }} color-{{ s.color_scheme }} spacing-style{% if use_iframe %} order-tracker--iframe-mode{% endif %}"
  style="{% render 'spacing-style', settings: s %}"
  data-testid="order-tracker-{{ section.id }}"
>
  <div class="order-tracker{% if use_iframe %} order-tracker--wide{% endif %}">
    {%- if s.heading != blank -%}
      <h1 class="order-tracker__heading">{{ s.heading }}</h1>
    {%- endif -%}
    {%- if s.subheading != blank -%}
      <p class="order-tracker__subheading">{{ s.subheading }}</p>
    {%- endif -%}

    <form
      class="order-tracker__form"
      data-method="{{ method }}"
      data-tracker-url="{{ tracker_url }}"
      data-order-param="{{ s.order_param | default: 'order_number' }}"
      data-email-param="{{ s.email_param | default: 'email' }}"
      data-use-iframe="{{ use_iframe }}"
      data-iframe-base="{{ iframe_base }}"
      data-require-email="{{ require_email }}"
    >
      <div class="order-tracker__field">
        <label for="ot-order-{{ section.id }}">{{ s.order_label | default: 'Order number' }}</label>
        <input type="text" id="ot-order-{{ section.id }}" name="order" autocomplete="off" required>
      </div>
      <div class="order-tracker__field{% if use_iframe and require_email == false %} order-tracker__field--hidden{% endif %}">
        <label for="ot-email-{{ section.id }}">{{ s.email_label | default: 'Email address' }}</label>
        <input type="email" id="ot-email-{{ section.id }}" name="email" autocomplete="email"{% if use_iframe and require_email == false %}{% else %} required{% endif %}>
      </div>
      <button type="submit" class="order-tracker__submit">{{ s.button_label | default: 'Track order' }}</button>
    </form>

    {%- if use_iframe -%}
      <div
        class="order-tracker__iframe-wrap"
        data-iframe-wrap
        style="--ot-iframe-height: {{ iframe_height }}px;"
        hidden
      >
        <iframe
          class="order-tracker__iframe"
          data-tracker-iframe
          src="about:blank"
          title="Tracking Iframe"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allow="clipboard-write"
        ></iframe>
      </div>
    {%- endif -%}

    {%- if s.help_text != blank -%}
      <div class="order-tracker__help rte">{{ s.help_text }}</div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .order-tracker {
    max-width: 520px;
    margin: 0 auto;
    padding-inline: var(--gap-md, 16px);
  }

  .order-tracker--wide {
    max-width: 1100px;
  }

  .order-tracker__field--hidden {
    display: none;
  }

  .order-tracker__iframe-wrap {
    margin-top: 28px;
    width: 100%;
    border-radius: 10px;
    overflow: hidden;
    background-color: rgb(var(--color-foreground, 0 0 0) / 0.03);
    border: 1px solid rgb(var(--color-foreground, 0 0 0) / 0.08);
  }

  .order-tracker__iframe {
    width: 100%;
    height: var(--ot-iframe-height, 800px);
    border: 0;
    display: block;
  }

  @media screen and (max-width: 749px) {
    .order-tracker__iframe {
      height: min(var(--ot-iframe-height, 800px), 75vh);
    }
  }

  .order-tracker__heading {
    margin: 0 0 12px;
    font-family: var(--font-heading--family);
    font-size: 32px;
    line-height: 1.15;
    text-align: center;
    color: rgb(var(--color-foreground-heading, 0 0 0));
  }

  .order-tracker__subheading {
    margin: 0 0 28px;
    text-align: center;
    font-size: 15px;
    color: rgb(var(--color-foreground, 0 0 0) / 0.7);
  }

  .order-tracker__form {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .order-tracker__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .order-tracker__field label {
    font-size: 13px;
    font-weight: 600;
    color: rgb(var(--color-foreground, 0 0 0));
  }

  .order-tracker__field input {
    padding: 12px 14px;
    border: 1px solid rgb(var(--color-foreground, 0 0 0) / 0.2);
    border-radius: 6px;
    font-size: 14px;
    background-color: rgb(var(--color-background, 255 255 255));
    color: rgb(var(--color-foreground, 0 0 0));
  }

  .order-tracker__field input:focus {
    outline: 2px solid rgb(var(--color-foreground, 0 0 0) / 0.4);
    outline-offset: 1px;
  }

  .order-tracker__submit {
    margin-top: 8px;
    padding: 14px 20px;
    border: none;
    border-radius: 6px;
    background-color: rgb(var(--color-foreground, 0 0 0));
    color: rgb(var(--color-background, 255 255 255));
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 200ms ease;
  }

  .order-tracker__submit:hover { opacity: 0.9; }

  .order-tracker__help {
    margin-top: 20px;
    padding: 14px 16px;
    background-color: rgb(var(--color-foreground, 0 0 0) / 0.04);
    border-radius: 8px;
    font-size: 13px;
    line-height: 1.5;
  }

  .order-tracker__help a { text-decoration: underline; }

  @media screen and (max-width: 749px) {
    .order-tracker__heading { font-size: 24px; }
  }
{% endstylesheet %}

<script>
  (function () {
    document.querySelectorAll('.order-tracker__form').forEach((form) => {
      if (form.dataset.bound) return;
      form.dataset.bound = 'true';
      form.addEventListener('submit', (event) => {
        event.preventDefault();
        const orderInput = form.querySelector('input[name="order"]');
        const emailInput = form.querySelector('input[name="email"]');
        const orderValue = (orderInput && orderInput.value || '').trim();
        if (!orderValue) {
          if (orderInput) orderInput.focus();
          return;
        }

        const useIframe = form.dataset.useIframe === 'true';
        const requireEmail = form.dataset.requireEmail === 'true';
        const emailValue = (emailInput && emailInput.value || '').trim();

        if ((!useIframe || requireEmail) && !emailValue) {
          if (emailInput) emailInput.focus();
          return;
        }

        if (useIframe) {
          const base = (form.dataset.iframeBase || '').replace(/\/+$/, '');
          const src = base + '/' + encodeURIComponent(orderValue);
          const wrap = form.parentElement.querySelector('[data-iframe-wrap]');
          const iframe = form.parentElement.querySelector('[data-tracker-iframe]');
          if (wrap && iframe) {
            iframe.src = src;
            wrap.hidden = false;
            requestAnimationFrame(() => {
              wrap.scrollIntoView({ behavior: 'smooth', block: 'start' });
            });
          }
          return;
        }

        const base = form.dataset.trackerUrl || '';
        const orderParam = form.dataset.orderParam || 'order_number';
        const emailParam = form.dataset.emailParam || 'email';
        const url = new URL(base, window.location.origin);
        url.searchParams.set(orderParam, orderValue);
        if (emailValue) url.searchParams.set(emailParam, emailValue);
        window.open(url.toString(), form.dataset.method === 'redirect' ? '_self' : '_blank');
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Order tracker",
  "tag": "section",
  "class": "section-order-tracker",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Track your order" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Enter your order number and email to see the latest status." },
    { "type": "text", "id": "order_label", "label": "Order field label", "default": "Order number" },
    { "type": "text", "id": "email_label", "label": "Email field label", "default": "Email address" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Track order" },
    { "type": "header", "content": "Tracker integration" },
    {
      "type": "checkbox",
      "id": "use_iframe",
      "label": "Show tracker in an iframe on this page",
      "info": "When enabled, submitting the form loads the tracker inline instead of opening AfterShip in another tab.",
      "default": true
    },
    {
      "type": "text",
      "id": "iframe_base_url",
      "label": "Iframe base URL",
      "info": "Order number is appended to the end of this URL, e.g. https://makeupcity.ginkgoretail.net/ordertracking/ORDERID",
      "default": "https://makeupcity.ginkgoretail.net/ordertracking/"
    },
    {
      "type": "range",
      "id": "iframe_height",
      "label": "Iframe height (desktop)",
      "min": 400,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 900
    },
    {
      "type": "checkbox",
      "id": "require_email",
      "label": "Require email field in iframe mode",
      "default": false
    },
    { "type": "text", "id": "tracker_url", "label": "External tracker URL (fallback)", "info": "Used only when iframe mode is off. Order + email are appended as query params.", "default": "https://track.aftership.com/" },
    { "type": "text", "id": "order_param", "label": "Order query param name", "default": "order_number" },
    { "type": "text", "id": "email_param", "label": "Email query param name", "default": "email" },
    {
      "type": "select",
      "id": "method",
      "label": "Open tracker in",
      "options": [
        { "value": "redirect", "label": "Same tab" },
        { "value": "new", "label": "New tab" }
      ],
      "default": "redirect"
    },
    { "type": "richtext", "id": "help_text", "label": "Help text", "default": "<p>Can't find your order number? Check your order confirmation email.</p>" },
    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding-block-start", "label": "Top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding-block-end", "label": "Bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 64 }
  ],
  "presets": [
    { "name": "Order tracker", "category": "Utility" }
  ]
}
{% endschema %}
