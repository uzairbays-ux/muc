{%- liquid
  assign s = section.settings
  assign base_url = s.iframe_base_url | default: 'https://makeupcity.ginkgoretail.net/ordertracking/'
-%}

<div
  class="section section--{{ s.section_width }} color-{{ s.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: s %}"
>
  <div class="order-tracker__iframe-wrap">
    <iframe
      class="order-tracker__iframe"
      src="{{ base_url }}"
      title="Track your order"
      loading="lazy"
      allowfullscreen
    ></iframe>
  </div>
</div>

{% stylesheet %}
  /* Full-width responsive iframe — no max-width constraint */
  .order-tracker__iframe-wrap {
    position: relative;
    width: 100%;
    /* Dynamic height: tall enough for the portal content on all screens */
    height: calc(100dvh - var(--header-group-height, 80px));
    min-height: 600px;
    overflow: hidden;
  }

  .order-tracker__iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  @media screen and (max-width: 749px) {
    .order-tracker__iframe-wrap {
      height: calc(100dvh - var(--header-group-height, 60px));
      min-height: 500px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Order tracker",
  "tag": "section",
  "class": "section-order-tracker",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "Tracking service" },
    {
      "type": "text",
      "id": "iframe_base_url",
      "label": "Tracking URL",
      "default": "https://makeupcity.ginkgoretail.net/ordertracking/",
      "info": "The full URL to embed directly in the iframe."
    },
    { "type": "header", "content": "Layout" },
    {
      "type": "select", "id": "section_width", "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "full-width"
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding-block-start", "label": "Top",    "min": 0, "max": 120, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding-block-end",   "label": "Bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 0 }
  ],
  "presets": [{ "name": "Order tracker" }]
}
{% endschema %}
