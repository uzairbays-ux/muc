<iframe
  src="{{ section.settings.iframe_base_url }}"
  style="display:block; width:100%; height:100vh; border:0;"
  title="Track your order"
  allowfullscreen
></iframe>

{% schema %}
{
  "name": "Order tracker",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "iframe_base_url",
      "label": "Tracking URL",
      "default": "https://makeupcity.ginkgoretail.net/ordertracking/"
    }
  ],
  "presets": [{ "name": "Order tracker" }]
}
{% endschema %}
