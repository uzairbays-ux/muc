<div class="order-tracker-wrap">
  <iframe
    class="order-tracker-iframe"
    src="{{ section.settings.iframe_url }}"
    title="Track your order"
    allowfullscreen
  ></iframe>
</div>

{% stylesheet %}
  .order-tracker-wrap {
    width: 100%;
    height: calc(100dvh - var(--header-group-height, 80px));
    min-height: 500px;
    position: relative;
  }

  .order-tracker-iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Order tracker",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "iframe_url",
      "label": "Tracking URL",
      "default": "https://makeupcity.ginkgoretail.net/ordertracking/",
      "info": "Full URL to load in the iframe."
    }
  ],
  "presets": [{ "name": "Order tracker" }]
}
{% endschema %}
