{%- liquid
  assign s = section.settings
  assign base_url = s.iframe_base_url | default: 'https://makeupcity.ginkgoretail.net/ordertracking/'
-%}

<div
  class="section section--{{ s.section_width }} color-{{ s.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: s %}"
>
  <order-tracker class="order-tracker">

    {%- comment -%} ── Form ── {%- endcomment -%}
    <div class="order-tracker__form-wrap" ref="formWrap">
      {%- if s.heading != blank -%}
        <h1 class="order-tracker__heading">{{ s.heading }}</h1>
      {%- endif -%}
      {%- if s.subheading != blank -%}
        <p class="order-tracker__subheading">{{ s.subheading }}</p>
      {%- endif -%}

      <form class="order-tracker__form" ref="form" novalidate>
        <div class="order-tracker__field">
          <label class="order-tracker__label" for="ot-order">{{ s.order_label | default: 'Order number' }}</label>
          <input
            id="ot-order"
            class="order-tracker__input"
            type="text"
            ref="orderInput"
            placeholder="{{ s.order_placeholder | default: 'e.g. 030426190053537294' }}"
            autocomplete="off"
            required
          >
          <p class="order-tracker__error" ref="orderError" hidden>Please enter your order number.</p>
        </div>

        <button type="submit" class="order-tracker__btn button">
          {{ s.button_label | default: 'Track order' }}
        </button>

        {%- if s.help_text != blank -%}
          <p class="order-tracker__help">{{ s.help_text }}</p>
        {%- endif -%}
      </form>
    </div>

    {%- comment -%} ── Results iframe ── {%- endcomment -%}
    <div class="order-tracker__result" ref="result" hidden>
      <div class="order-tracker__result-header">
        <p class="order-tracker__result-label" ref="resultLabel">Tracking results</p>
        <button class="order-tracker__back" ref="back" type="button">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          Track another order
        </button>
      </div>
      <div class="order-tracker__iframe-wrap">
        <iframe
          ref="iframe"
          class="order-tracker__iframe"
          src="about:blank"
          title="Order tracking"
          loading="lazy"
          style="height: {{ s.iframe_height | default: 900 }}px"
        ></iframe>
      </div>
    </div>

  </order-tracker>
</div>

{% stylesheet %}
  .order-tracker {
    display: block;
    max-width: 560px;
    margin: 0 auto;
    padding-inline: var(--gap-md, 20px);
  }

  /* ── Form ── */
  .order-tracker__form-wrap {
    text-align: center;
  }

  .order-tracker__heading {
    margin: 0 0 12px;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    color: rgb(var(--color-foreground-heading, 0 0 0));
  }

  .order-tracker__subheading {
    margin: 0 0 32px;
    font-size: 15px;
    color: rgb(var(--color-foreground, 0 0 0) / 0.65);
    line-height: 1.5;
  }

  .order-tracker__form {
    display: flex;
    flex-direction: column;
    gap: 20px;
    text-align: left;
  }

  .order-tracker__field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .order-tracker__label {
    font-size: 14px;
    font-weight: 600;
    color: rgb(var(--color-foreground, 0 0 0));
  }

  .order-tracker__input {
    width: 100%;
    padding: 13px 16px;
    border: 1.5px solid rgb(var(--color-foreground, 0 0 0) / 0.2);
    border-radius: 8px;
    font-size: 15px;
    background: rgb(var(--color-background, 255 255 255));
    color: rgb(var(--color-foreground, 0 0 0));
    transition: border-color 0.18s;
  }

  .order-tracker__input:focus {
    outline: none;
    border-color: rgb(255 16 16);
  }

  .order-tracker__input.is-invalid {
    border-color: #e53e3e;
  }

  .order-tracker__error {
    margin: 0;
    font-size: 12px;
    color: #e53e3e;
  }

  .order-tracker__btn {
    width: 100%;
    padding: 14px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
  }

  .order-tracker__help {
    margin: 0;
    text-align: center;
    font-size: 13px;
    color: rgb(var(--color-foreground, 0 0 0) / 0.55);
  }

  .order-tracker__help a {
    color: inherit;
    text-decoration: underline;
  }

  /* ── Results ── */
  .order-tracker__result {
    width: 100%;
    max-width: 960px;
    margin: 0 auto;
  }

  .order-tracker__result-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgb(var(--color-foreground, 0 0 0) / 0.1);
  }

  .order-tracker__result-label {
    margin: 0;
    font-size: 15px;
    font-weight: 600;
    color: rgb(var(--color-foreground, 0 0 0));
  }

  .order-tracker__back {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: none;
    border: none;
    font-size: 13px;
    font-weight: 500;
    color: rgb(255 16 16);
    cursor: pointer;
    padding: 0;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .order-tracker__back:hover {
    color: rgb(180 0 0);
  }

  .order-tracker__iframe-wrap {
    border-radius: 12px;
    overflow: hidden;
    border: 1.5px solid rgb(var(--color-foreground, 0 0 0) / 0.1);
    background: #fff;
  }

  .order-tracker__iframe {
    display: block;
    width: 100%;
    border: 0;
  }

  @media screen and (max-width: 749px) {
    .order-tracker__heading { font-size: 1.6rem; }
    .order-tracker__iframe { height: 600px !important; }
  }
{% endstylesheet %}

<script>
  (function () {
    if (customElements.get('order-tracker')) return;

    class OrderTracker extends HTMLElement {
      connectedCallback() {
        this._baseUrl     = {{ base_url | json }};
        this._form        = this.querySelector('[ref="form"]');
        this._formWrap    = this.querySelector('[ref="formWrap"]');
        this._result      = this.querySelector('[ref="result"]');
        this._iframe      = this.querySelector('[ref="iframe"]');
        this._back        = this.querySelector('[ref="back"]');
        this._orderInput  = this.querySelector('[ref="orderInput"]');
        this._orderError  = this.querySelector('[ref="orderError"]');
        this._resultLabel = this.querySelector('[ref="resultLabel"]');

        this._form?.addEventListener('submit', (e) => {
          e.preventDefault();
          this._track();
        });

        this._back?.addEventListener('click', () => this._reset());
      }

      _track() {
        const order = this._orderInput?.value.trim();

        if (!order) {
          this._orderInput?.classList.add('is-invalid');
          if (this._orderError) this._orderError.hidden = false;
          this._orderInput?.focus();
          return;
        }

        this._orderInput?.classList.remove('is-invalid');
        if (this._orderError) this._orderError.hidden = true;

        // Append order number to base URL
        const url = this._baseUrl.replace(/\/$/, '') + '/' + encodeURIComponent(order);

        if (this._iframe) this._iframe.src = url;
        if (this._resultLabel) this._resultLabel.textContent = 'Order #' + order;

        this._formWrap.hidden = true;
        this._result.hidden   = false;
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      _reset() {
        if (this._iframe) this._iframe.src = 'about:blank';
        this._result.hidden   = true;
        this._formWrap.hidden = false;
        if (this._orderInput) this._orderInput.value = '';
        this._orderInput?.focus();
      }
    }

    customElements.define('order-tracker', OrderTracker);
  })();
</script>

{% schema %}
{
  "name": "Order tracker",
  "tag": "section",
  "class": "section-order-tracker",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text",     "id": "heading",           "label": "Heading",              "default": "Track your order" },
    { "type": "text",     "id": "subheading",         "label": "Subheading",           "default": "Enter your order number to see the latest status." },
    { "type": "text",     "id": "order_label",        "label": "Order number label",   "default": "Order number" },
    { "type": "text",     "id": "order_placeholder",  "label": "Order number placeholder", "default": "e.g. 030426190053537294" },
    { "type": "text",     "id": "button_label",       "label": "Button label",         "default": "Track order" },
    { "type": "richtext", "id": "help_text",          "label": "Help text",            "default": "<p>Can't find your order number? Check your order confirmation email.</p>" },
    { "type": "header",   "content": "Tracking service" },
    { "type": "text",     "id": "iframe_base_url",    "label": "Tracking base URL",    "default": "https://makeupcity.ginkgoretail.net/ordertracking/", "info": "Order number is appended to this URL automatically." },
    { "type": "range",    "id": "iframe_height",      "label": "Iframe height (desktop)", "min": 400, "max": 1400, "step": 50, "unit": "px", "default": 900 },
    { "type": "header",   "content": "Layout" },
    {
      "type": "select", "id": "section_width", "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header",   "content": "Padding" },
    { "type": "range", "id": "padding-block-start", "label": "Top",    "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding-block-end",   "label": "Bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 64 }
  ],
  "presets": [
    { "name": "Order tracker" }
  ]
}
{% endschema %}
