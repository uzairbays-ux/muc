{% liquid
  assign s = section.settings
  assign desktop_columns = s.desktop_columns | default: 4
  assign mobile_columns = s.mobile_columns | default: 2
  assign gap = s.gap | default: 16
  assign desktop_layout = s.desktop_layout | default: 'grid'
  assign mobile_layout = s.mobile_layout | default: 'grid'
  assign desktop_slider_per_view = s.desktop_slider_per_view | default: desktop_columns
  assign mobile_slider_per_view = s.mobile_slider_per_view | default: '2'
  assign auto_rotate = s.auto_rotate
  assign rotate_interval = s.rotate_interval | default: 4
  assign desktop_side_padding = s.desktop_side_padding | default: 48
%}

<div class="section-background color-{{ s.color_scheme }}"></div>
<div
  class="section section--{{ s.section_width }} color-{{ s.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: s %}"
  data-testid="card-grid-{{ section.id }}"
>
  {%- if s.heading != blank -%}
    <div class="card-grid__header" style="text-align: {{ s.heading_alignment }};">
      <h2 class="card-grid__heading h3">{{ s.heading }}</h2>
      {%- if s.subheading != blank -%}
        <p class="card-grid__subheading">{{ s.subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <card-grid-slider
    class="card-grid__grid"
    data-desktop-layout="{{ desktop_layout }}"
    data-mobile-layout="{{ mobile_layout }}"
    data-auto-rotate="{{ auto_rotate }}"
    data-rotate-interval="{{ rotate_interval }}"
    style="--cg-desktop-cols: {{ desktop_columns }}; --cg-mobile-cols: {{ mobile_columns }}; --cg-desktop-per-view: {{ desktop_slider_per_view }}; --cg-mobile-per-view: {{ mobile_slider_per_view }}; --cg-gap: {{ gap }}px; --cg-desktop-side-padding: {{ desktop_side_padding }}px;"
  >
    {%- for block in section.blocks -%}
      {%- assign b = block.settings -%}
      <div class="card-grid__item" {{ block.shopify_attributes }}>
        {%- if b.link != blank -%}
          <a href="{{ b.link }}" class="card-grid__link" {% if b.open_new_tab %}target="_blank" rel="noopener"{% endif %}>
        {%- endif -%}
          <div class="card-grid__image-wrapper">
            {%- if b.image != blank -%}
              {{
                b.image
                | image_url: width: 900
                | image_tag:
                  loading: 'lazy',
                  widths: '400,600,750,900',
                  sizes: '(max-width: 749px) 50vw, 25vw',
                  class: 'card-grid__image',
                  alt: b.image.alt | default: ''
              }}
            {%- else -%}
              <div class="card-grid__placeholder">
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>
        {%- if b.link != blank -%}
          </a>
        {%- endif -%}
      </div>
    {%- else -%}
      {%- for i in (1..4) -%}
        <div class="card-grid__item">
          <div class="card-grid__image-wrapper">
            <div class="card-grid__placeholder">
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- endfor -%}
  </card-grid-slider>
</div>

{% stylesheet %}
  .card-grid__header {
    margin-bottom: var(--gap-md, 16px);
  }

  .card-grid__heading {
    margin: 0;
    font-family: var(--font-heading--family);
    color: rgb(var(--color-foreground-heading));
  }

  .card-grid__subheading {
    margin: var(--gap-2xs, 4px) 0 0;
    color: rgb(var(--color-foreground));
    opacity: 0.7;
  }

  .card-grid__grid {
    display: grid;
    grid-template-columns: repeat(var(--cg-desktop-cols, 4), 1fr);
    gap: var(--cg-gap, 16px);
  }

  /* Desktop slider mode */
  @media screen and (min-width: 750px) {
    /* Desktop-only side padding applies to BOTH grid and slider modes */
    .card-grid__grid {
      padding-inline: var(--cg-desktop-side-padding, 48px);
    }

    .card-grid__grid[data-desktop-layout="slider"] {
      display: flex;
      grid-template-columns: none;
      gap: var(--cg-gap, 16px);
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding: 0 var(--cg-desktop-side-padding, 48px);
      scroll-padding-inline: var(--cg-desktop-side-padding, 48px);
    }

    .card-grid__grid[data-desktop-layout="slider"]::-webkit-scrollbar {
      display: none;
    }

    .card-grid__grid[data-desktop-layout="slider"] .card-grid__item {
      flex: 0 0 calc((100% - (var(--cg-gap, 16px) * (var(--cg-desktop-per-view) - 1))) / var(--cg-desktop-per-view));
      min-width: 0;
      scroll-snap-align: start;
    }
  }

  @media screen and (max-width: 749px) {
    .card-grid__grid {
      grid-template-columns: repeat(var(--cg-mobile-cols, 2), 1fr);
    }

    /* Mobile slider mode */
    .card-grid__grid[data-mobile-layout="slider"] {
      display: flex;
      grid-template-columns: none;
      gap: var(--cg-gap, 16px);
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding: 0 var(--gap-md, 16px);
      scroll-padding-inline: var(--gap-md, 16px);
    }

    .card-grid__grid[data-mobile-layout="slider"]::-webkit-scrollbar {
      display: none;
    }

    .card-grid__grid[data-mobile-layout="slider"] .card-grid__item {
      flex: 0 0 calc((100% - (var(--cg-gap, 16px) * (var(--cg-mobile-per-view) - 1))) / var(--cg-mobile-per-view));
      min-width: 0;
      scroll-snap-align: start;
    }
  }

  .card-grid__item {
    position: relative;
    border-radius: var(--style-border-radius-card, 8px);
    overflow: hidden;
  }

  .card-grid__link {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: var(--style-border-radius-card, 8px);
    overflow: hidden;
    transition: transform 200ms ease, box-shadow 200ms ease;
  }

  .card-grid__link:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgb(0 0 0 / 0.1);
  }

  .card-grid__image-wrapper {
    position: relative;
    width: 100%;
  }

  .card-grid__image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .card-grid__placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: rgb(var(--color-foreground) / 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-grid__placeholder .placeholder-svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }
{% endstylesheet %}

<script>
  (function () {
    if (customElements.get('card-grid-slider')) return;

    class CardGridSlider extends HTMLElement {
      connectedCallback() {
        if (this.dataset.autoRotate !== 'true') return;

        const seconds = parseInt(this.dataset.rotateInterval, 10);
        this.intervalMs = (isNaN(seconds) || seconds < 2 ? 4 : seconds) * 1000;
        this.isPaused = false;

        this.addEventListener('mouseenter', () => { this.isPaused = true; });
        this.addEventListener('mouseleave', () => { this.isPaused = false; });
        this.addEventListener('touchstart', () => {
          this.isPaused = true;
          clearTimeout(this._resumeTimer);
          this._resumeTimer = setTimeout(() => { this.isPaused = false; }, 5000);
        }, { passive: true });

        if (typeof IntersectionObserver !== 'undefined') {
          this._io = new IntersectionObserver((entries) => {
            entries.forEach((entry) => { this._inView = entry.isIntersecting; });
          }, { threshold: 0.2 });
          this._io.observe(this);
        } else {
          this._inView = true;
        }

        this._tick = setInterval(() => this.step(), this.intervalMs);
      }

      disconnectedCallback() {
        clearInterval(this._tick);
        clearTimeout(this._resumeTimer);
        if (this._io) this._io.disconnect();
      }

      currentLayout() {
        const isDesktop = window.matchMedia('(min-width: 750px)').matches;
        return isDesktop ? this.dataset.desktopLayout : this.dataset.mobileLayout;
      }

      step() {
        if (this.isPaused) return;
        if (this._inView === false) return;
        if (this.currentLayout() !== 'slider') return;
        if (this.scrollWidth <= this.clientWidth + 1) return;

        const firstItem = this.querySelector('.card-grid__item');
        if (!firstItem) return;

        const styles = getComputedStyle(this);
        const gap = parseFloat(styles.columnGap || styles.gap || '0') || 0;
        const delta = firstItem.offsetWidth + gap;

        const atEnd = this.scrollLeft + this.clientWidth >= this.scrollWidth - 2;
        if (atEnd) {
          this.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
          this.scrollBy({ left: delta, behavior: 'smooth' });
        }
      }
    }

    customElements.define('card-grid-slider', CardGridSlider);
  })();
</script>

{% schema %}
{
  "name": "Card grid",
  "tag": "section",
  "class": "section-card-grid",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Layout mode"
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "label": "Desktop layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "slider", "label": "Slider" }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "slider", "label": "Slider" }
      ],
      "default": "grid"
    },
    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "select",
      "id": "desktop_columns",
      "label": "Desktop columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" },
        { "value": "6", "label": "6" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Mobile columns",
      "options": [
        { "value": "1", "label": "1 (stacked)" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "Slider (when enabled)"
    },
    {
      "type": "select",
      "id": "desktop_slider_per_view",
      "label": "Desktop cards per view",
      "info": "Used when Desktop layout is Slider.",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" },
        { "value": "6", "label": "6" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "mobile_slider_per_view",
      "label": "Mobile cards per view",
      "info": "Used when Mobile layout is Slider. Peek size depends on the fractional part — higher values (e.g. 1.5) show more of the next card.",
      "options": [
        { "value": "1", "label": "1 (full width, no peek)" },
        { "value": "1.2", "label": "1.2 (small peek)" },
        { "value": "1.3", "label": "1.3" },
        { "value": "1.5", "label": "1.5 (recommended for banners)" },
        { "value": "2", "label": "2" },
        { "value": "2.2", "label": "2.2" },
        { "value": "2.5", "label": "2.5" }
      ],
      "default": "1.5"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate slider",
      "info": "Automatically scrolls to the next card. Pauses on hover/touch. Only applies in Slider mode.",
      "default": false
    },
    {
      "type": "range",
      "id": "rotate_interval",
      "label": "Rotation interval",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 4
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between cards",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "desktop_side_padding",
      "label": "Desktop side padding",
      "info": "Left/right padding applied on desktop only. Mobile stays edge-to-edge.",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Height adapts to image aspect ratio — no cropping."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Makes the entire card clickable."
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Open link in new tab",
          "default": false
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Card grid",
      "category": "Banners",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}
