{% liquid
  assign s = section.settings
  assign desktop_per_view = s.desktop_per_view | default: 6
  assign mobile_per_view = s.mobile_per_view | default: '2.2'
  assign gap = s.gap | default: 8
  assign bg_color = s.background_color
  assign caption_size_desktop = s.caption_size_desktop | default: 14
  assign caption_size_mobile = s.caption_size_mobile | default: 12
%}

<div
  class="section section--{{ s.section_width }} spacing-style"
  style="{% render 'spacing-style', settings: s %}{% if bg_color != blank %} background-color: {{ bg_color }};{% endif %}"
  data-testid="story-cards-{{ section.id }}"
>
  {%- if s.heading != blank -%}
    <div class="story-cards__header" style="text-align: {{ s.heading_alignment }};">
      <h2 class="story-cards__heading h3">{{ s.heading }}</h2>
      {%- if s.subheading != blank -%}
        <p class="story-cards__subheading">{{ s.subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <story-cards-section
    class="story-cards"
    style="--sc-desktop-per-view: {{ desktop_per_view }}; --sc-mobile-per-view: {{ mobile_per_view }}; --sc-gap: {{ gap }}px; --sc-caption-desktop: {{ caption_size_desktop }}px; --sc-caption-mobile: {{ caption_size_mobile }}px;"
  >
    <div class="story-cards__track">
      {%- for block in section.blocks -%}
        {%- assign b = block.settings -%}
        <div class="story-cards__card" {{ block.shopify_attributes }}>
          {%- if b.link != blank -%}
            <a href="{{ b.link }}" class="story-cards__link" {% if b.open_new_tab %}target="_blank" rel="noopener"{% endif %}>
          {%- endif -%}

            <div class="story-cards__media">
              {%- if b.preview_video != blank -%}
                <video
                  class="story-cards__video"
                  src="{{ b.preview_video }}"
                  muted
                  loop
                  playsinline
                  preload="metadata"
                  {% if b.cover_image != blank %}poster="{{ b.cover_image | image_url: width: 600 }}"{% endif %}
                ></video>
              {%- elsif b.cover_image != blank -%}
                {{
                  b.cover_image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    widths: '300,500,800',
                    sizes: '(max-width: 749px) 45vw, 17vw',
                    class: 'story-cards__image',
                    alt: b.cover_image.alt | default: b.caption | default: ''
                }}
              {%- else -%}
                <div class="story-cards__placeholder">
                  {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {%- endif -%}

              {%- if b.brand_logo != blank -%}
                <div class="story-cards__logo">
                  {{
                    b.brand_logo
                    | image_url: width: 120
                    | image_tag:
                      loading: 'lazy',
                      class: 'story-cards__logo-image',
                      alt: b.brand_logo.alt | default: ''
                  }}
                </div>
              {%- endif -%}

              {%- if b.caption != blank -%}
                <div class="story-cards__caption">{{ b.caption }}</div>
              {%- endif -%}
            </div>

          {%- if b.link != blank -%}
            </a>
          {%- endif -%}
        </div>
      {%- else -%}
        {%- for i in (1..6) -%}
          <div class="story-cards__card">
            <div class="story-cards__media">
              <div class="story-cards__placeholder">
                {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
              <div class="story-cards__caption">Story caption {{ i }}</div>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </story-cards-section>
</div>

{% stylesheet %}
  .story-cards__header {
    margin-bottom: var(--gap-md, 16px);
    padding-inline: var(--gap-md, 16px);
  }

  .story-cards__heading {
    margin: 0;
    font-family: var(--font-heading--family);
    color: rgb(var(--color-foreground-heading));
  }

  .story-cards__subheading {
    margin: var(--gap-2xs, 4px) 0 0;
    color: rgb(var(--color-foreground));
    opacity: 0.7;
  }

  .story-cards {
    display: block;
  }

  .story-cards__track {
    display: flex;
    gap: var(--sc-gap, 8px);
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0 var(--gap-md, 16px);
    scroll-padding-inline: var(--gap-md, 16px);
  }

  .story-cards__track::-webkit-scrollbar {
    display: none;
  }

  .story-cards__card {
    flex: 0 0 calc((100% - (var(--sc-gap) * (var(--sc-desktop-per-view) - 1))) / var(--sc-desktop-per-view));
    scroll-snap-align: start;
  }

  @media screen and (max-width: 749px) {
    .story-cards__card {
      flex: 0 0 calc((100% - (var(--sc-gap) * (var(--sc-mobile-per-view) - 1))) / var(--sc-mobile-per-view));
    }
  }

  .story-cards__link {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform 200ms ease;
  }

  .story-cards__link:hover {
    transform: translateY(-2px);
  }

  .story-cards__media {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 16;
    border-radius: var(--style-border-radius-card, 12px);
    overflow: hidden;
    background-color: #1a1a1a;
  }

  .story-cards__image,
  .story-cards__video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .story-cards__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #2a2a2a;
  }

  .story-cards__placeholder .placeholder-svg {
    width: 40%;
    height: 40%;
    opacity: 0.3;
  }

  /* Brand logo (top-right corner) */
  .story-cards__logo {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 2;
    max-width: 40%;
    max-height: 24px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .story-cards__logo-image {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.4));
  }

  /* Caption (bottom overlay) */
  .story-cards__caption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 40px 12px 14px;
    font-size: var(--sc-caption-desktop, 14px);
    line-height: 1.3;
    color: #ffffff;
    text-align: center;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.75) 0%,
      rgba(0, 0, 0, 0.4) 50%,
      rgba(0, 0, 0, 0) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .story-cards__caption {
      font-size: var(--sc-caption-mobile, 12px);
      padding: 32px 10px 12px;
    }

    .story-cards__logo {
      top: 8px;
      right: 8px;
      max-height: 18px;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    if (customElements.get('story-cards-section')) return;

    class StoryCardsSection extends HTMLElement {
      connectedCallback() {
        this.videos = this.querySelectorAll('.story-cards__video');
        if (!this.videos.length) return;

        this.observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.play().catch(() => {});
              } else {
                entry.target.pause();
              }
            });
          },
          { threshold: 0.3 }
        );
        this.videos.forEach((v) => this.observer.observe(v));
      }

      disconnectedCallback() {
        if (this.observer) this.observer.disconnect();
      }
    }

    customElements.define('story-cards-section', StoryCardsSection);
  })();
</script>

{% schema %}
{
  "name": "Story cards",
  "tag": "section",
  "class": "section-story-cards",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "full-width"
    },
    {
      "type": "select",
      "id": "desktop_per_view",
      "label": "Desktop cards per view",
      "options": [
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" },
        { "value": "6", "label": "6" },
        { "value": "7", "label": "7" },
        { "value": "8", "label": "8" }
      ],
      "default": "6"
    },
    {
      "type": "select",
      "id": "mobile_per_view",
      "label": "Mobile cards per view",
      "options": [
        { "value": "1.5", "label": "1.5" },
        { "value": "2", "label": "2" },
        { "value": "2.2", "label": "2.2" },
        { "value": "2.5", "label": "2.5" },
        { "value": "3", "label": "3" }
      ],
      "default": "2.2"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between cards",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "caption_size_desktop",
      "label": "Caption size (desktop)",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "caption_size_mobile",
      "label": "Caption size (mobile)",
      "min": 9,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background color"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "story_card",
      "name": "Story card",
      "settings": [
        {
          "type": "image_picker",
          "id": "cover_image",
          "label": "Cover image",
          "info": "Used if no video is set, or as video poster."
        },
        {
          "type": "text",
          "id": "preview_video",
          "label": "Video URL",
          "info": "Optional. Direct .mp4 URL (from Files). Auto-plays muted on scroll."
        },
        {
          "type": "image_picker",
          "id": "brand_logo",
          "label": "Brand logo",
          "info": "Shown in top-right corner."
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption",
          "info": "Text overlay at the bottom of the card."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Open link in new tab",
          "default": false
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Story cards",
      "category": "Video",
      "blocks": [
        { "type": "story_card" },
        { "type": "story_card" },
        { "type": "story_card" },
        { "type": "story_card" },
        { "type": "story_card" },
        { "type": "story_card" }
      ]
    }
  ]
}
{% endschema %}
