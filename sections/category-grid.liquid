{% liquid
  assign s = section.settings
  assign layout = s.layout | default: 'carousel'
  assign desktop_per_row = s.desktop_per_row | default: 8
  assign mobile_per_row = s.mobile_per_row | default: '3.5'
  assign gap = s.gap | default: 12
  assign row_gap = s.row_gap | default: 12
  assign bg_color = s.background_color | default: 'transparent'
  assign show_arrows = s.show_arrows
  assign image_padding = s.image_padding | default: 8
  assign image_fit = s.image_fit | default: 'contain'
  assign card_ratio = s.card_ratio | default: 'square'
  assign image_border_radius = s.image_border_radius | default: 12
  assign mobile_per_row_int = mobile_per_row | times: 1.0 | floor
  if mobile_per_row_int < 1
    assign mobile_per_row_int = 2
  endif
%}

<div
  class="section section--full-width spacing-style"
  style="{% render 'spacing-style', settings: s %} background-color: {{ bg_color }};"
  data-testid="category-grid-{{ section.id }}"
>
  {%- if s.heading != blank -%}
    <div class="category-grid__header" style="text-align: {{ s.heading_alignment }};">
      <h2 class="category-grid__heading h3">{{ s.heading }}</h2>
      {%- if s.subheading != blank -%}
        <p class="category-grid__subheading">{{ s.subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <category-grid-slider
    class="category-grid"
    data-layout="{{ layout }}"
    style="--cg-desktop-per-row: {{ desktop_per_row }}; --cg-mobile-per-row: {{ mobile_per_row }}; --cg-mobile-per-row-int: {{ mobile_per_row_int }}; --cg-gap: {{ gap }}px; --cg-row-gap: {{ row_gap }}px; --cg-image-radius: {{ image_border_radius }}px;"
  >
    <div class="category-grid__viewport" ref="viewport">
      <div class="category-grid__track" ref="track">
        {%- for block in section.blocks -%}
          {%- assign b = block.settings -%}
          {%- assign card_bg = b.card_background | default: '#f5f0ff' -%}
          <div class="category-grid__card" {{ block.shopify_attributes }}>
            {%- if b.link != blank -%}
              <a href="{{ b.link }}" class="category-grid__link">
            {%- endif -%}
              <div class="category-grid__image-wrapper" style="--cg-padding: {{ image_padding }}%; --cg-image-fit: {{ image_fit }}; --cg-ratio: {{ card_ratio }}; background-color: {{ card_bg }};">
                {%- if b.image != blank -%}
                  {{
                    b.image
                    | image_url: width: 400
                    | image_tag:
                      loading: 'lazy',
                      widths: '200,300,400',
                      sizes: '(max-width: 749px) 28vw, 12vw',
                      class: 'category-grid__image',
                      alt: b.image.alt | default: b.label | default: ''
                  }}
                {%- else -%}
                  <div class="category-grid__placeholder">
                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  </div>
                {%- endif -%}
              </div>
              {%- if b.label != blank -%}
                <span class="category-grid__label">{{ b.label }}</span>
              {%- endif -%}
            {%- if b.link != blank -%}
              </a>
            {%- endif -%}
          </div>
        {%- else -%}
          {%- for i in (1..16) -%}
            <div class="category-grid__card">
              <div class="category-grid__image-wrapper" style="--cg-padding: 8%; --cg-image-fit: contain; --cg-ratio: square; background-color: #f5f0ff;">
                <div class="category-grid__placeholder">
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              </div>
              <span class="category-grid__label">Category {{ i }}</span>
            </div>
          {%- endfor -%}
        {%- endfor -%}
      </div>

      {%- if show_arrows and section.blocks.size > 1 and layout == 'carousel' -%}
        <button
          type="button"
          class="category-grid__arrow category-grid__arrow--prev button-unstyled"
          aria-label="Scroll left"
          ref="prev"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <button
          type="button"
          class="category-grid__arrow category-grid__arrow--next button-unstyled"
          aria-label="Scroll right"
          ref="next"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      {%- endif -%}
    </div>
  </category-grid-slider>
</div>

{% stylesheet %}
  .category-grid__header {
    margin-bottom: var(--gap-md, 16px);
    padding-inline: var(--gap-md, 16px);
  }

  .category-grid__heading {
    margin: 0;
    font-family: var(--font-heading--family);
    color: rgb(var(--color-foreground-heading));
  }

  .category-grid__subheading {
    display: block;
    margin: var(--gap-2xs, 4px) 0 0;
    font-size: 14px;
    line-height: 1.4;
    color: rgb(var(--color-foreground, 0 0 0) / 0.75);
  }

  .category-grid {
    display: block;
    position: relative;
  }

  .category-grid__viewport {
    position: relative;
  }

  .category-grid__track {
    display: grid;
    grid-template-rows: repeat(2, auto);
    grid-auto-flow: column;
    grid-auto-columns: calc((100% - (var(--cg-gap) * (var(--cg-desktop-per-row) - 1))) / var(--cg-desktop-per-row));
    gap: var(--cg-row-gap) var(--cg-gap);
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0 var(--gap-md, 16px);
    scroll-padding-inline: var(--gap-md, 16px);
  }

  .category-grid__track::-webkit-scrollbar {
    display: none;
  }

  /* Grid layout: normal wrapping grid, no horizontal scroll */
  .category-grid[data-layout="grid"] .category-grid__track {
    grid-template-rows: none;
    grid-auto-flow: row;
    grid-auto-columns: unset;
    grid-template-columns: repeat(var(--cg-desktop-per-row), 1fr);
    overflow-x: visible;
    overflow-y: visible;
    scroll-snap-type: none;
  }

  @media screen and (max-width: 749px) {
    .category-grid__track {
      grid-auto-columns: calc((100% - (var(--cg-gap) * (var(--cg-mobile-per-row) - 1))) / var(--cg-mobile-per-row));
    }

    .category-grid[data-layout="grid"] .category-grid__track {
      grid-auto-columns: unset;
      grid-template-columns: repeat(var(--cg-mobile-per-row-int, 2), 1fr);
    }
  }

  .category-grid__card {
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    min-width: 0;
  }

  .category-grid__link {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: inherit;
    width: 100%;
    transition: transform 200ms ease;
  }

  .category-grid__link:hover {
    transform: translateY(-2px);
  }

  .category-grid__image-wrapper {
    width: 100%;
    aspect-ratio: var(--cg-ratio-value, 1 / 1);
    border-radius: var(--cg-image-radius, 12px);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--cg-padding, 8%);
  }

  .category-grid__card[style*="--cg-ratio: adapt"] .category-grid__image-wrapper,
  .category-grid__image-wrapper[style*="--cg-ratio: adapt"] {
    aspect-ratio: auto;
  }

  .category-grid__image-wrapper[style*="--cg-ratio: portrait"] {
    aspect-ratio: 3 / 4;
  }

  .category-grid__image-wrapper[style*="--cg-ratio: landscape"] {
    aspect-ratio: 4 / 3;
  }

  .category-grid__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: var(--cg-image-fit, contain);
  }

  .category-grid__placeholder {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .category-grid__placeholder .placeholder-svg {
    width: 100%;
    height: 100%;
  }

  .category-grid__label {
    display: block;
    margin-top: 8px;
    font-size: 13px;
    font-weight: 600;
    line-height: 1.3;
    color: rgb(var(--color-foreground));
    word-wrap: break-word;
    max-width: 100%;
    text-align: center;
  }

  @media screen and (max-width: 749px) {
    .category-grid__label {
      font-size: 11px;
    }
  }

  /* Arrows --------------------------------------------------------------- */
  .category-grid__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.9);
    color: #333;
    box-shadow: 0 2px 8px rgb(0 0 0 / 0.12);
    backdrop-filter: blur(4px);
    transition: opacity 200ms ease;
    cursor: pointer;
    border: none;
    padding: 0;
  }

  .category-grid__arrow:hover {
    background-color: #fff;
  }

  .category-grid__arrow--prev { left: 8px; }
  .category-grid__arrow--next { right: 8px; }

  .category-grid__arrow svg {
    width: 18px;
    height: 18px;
  }

  @media screen and (max-width: 749px) {
    .category-grid__arrow {
      width: 30px;
      height: 30px;
    }
    .category-grid__arrow svg { width: 14px; height: 14px; }
    .category-grid__arrow--prev { left: 4px; }
    .category-grid__arrow--next { right: 4px; }
  }
{% endstylesheet %}

<script>
  (function () {
    if (customElements.get('category-grid-slider')) return;

    class CategoryGridSlider extends HTMLElement {
      connectedCallback() {
        this.track = this.querySelector('[ref="track"]');
        this.prevBtn = this.querySelector('[ref="prev"]');
        this.nextBtn = this.querySelector('[ref="next"]');
        if (!this.track) return;

        if (this.prevBtn) this.prevBtn.addEventListener('click', () => this.scrollByCards(-1));
        if (this.nextBtn) this.nextBtn.addEventListener('click', () => this.scrollByCards(1));
      }

      scrollByCards(direction) {
        const card = this.track.querySelector('.category-grid__card');
        if (!card) return;
        const cardWidth = card.offsetWidth + parseFloat(getComputedStyle(this.track).columnGap || '0');
        const scrollAmount = direction * cardWidth * 3;
        this.track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      }
    }

    customElements.define('category-grid-slider', CategoryGridSlider);
  })();
</script>

{% schema %}
{
