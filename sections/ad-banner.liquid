{% liquid
  assign s = section.settings
%}

<div
  class="section section--{{ s.section_width }} spacing-style"
  style="{% render 'spacing-style', settings: s %}"
  data-testid="ad-banner-{{ section.id }}"
>
  {%- if s.link != blank -%}
    <a href="{{ s.link }}" class="ad-banner__link" {% if s.open_new_tab %}target="_blank" rel="noopener"{% endif %}>
  {%- endif -%}

    <picture class="ad-banner__picture">
      {%- if s.mobile_image != blank -%}
        <source
          media="(max-width: 749px)"
          srcset="{{ s.mobile_image | image_url: width: 750 }} 750w, {{ s.mobile_image | image_url: width: 1080 }} 1080w"
          sizes="100vw"
          width="{{ s.mobile_image.width }}"
          height="{{ s.mobile_image.height }}"
        >
      {%- endif -%}
      {%- if s.desktop_image != blank -%}
        {{
          s.desktop_image
          | image_url: width: 2400
          | image_tag:
            loading: 'lazy',
            widths: '750,1100,1500,1800,2200,2400',
            sizes: '100vw',
            class: 'ad-banner__image',
            alt: s.desktop_image.alt | default: 'Promotion banner'
        }}
      {%- else -%}
        <div class="ad-banner__placeholder">
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}
    </picture>

  {%- if s.link != blank -%}
    </a>
  {%- endif -%}
</div>

{% stylesheet %}
  .ad-banner__link {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: var(--style-border-radius-card, 8px);
    overflow: hidden;
  }

  .ad-banner__picture {
    display: block;
    width: 100%;
    border-radius: var(--style-border-radius-card, 8px);
    overflow: hidden;
  }

  .ad-banner__link .ad-banner__picture {
    border-radius: 0;
  }

  .ad-banner__image {
    display: block;
    width: 100%;
    height: auto;
  }

  .ad-banner__placeholder {
    width: 100%;
    aspect-ratio: 6 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ad-banner__placeholder .placeholder-svg {
    width: 30%;
    height: 50%;
    opacity: 0.3;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Ad banner",
  "tag": "section",
  "class": "section-ad-banner",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image",
      "info": "Wide banner for screens 750px and above. Height adapts to image."
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "Optional. Different size/layout for phones under 750px."
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link",
      "info": "Makes the entire banner clickable."
    },
    {
      "type": "checkbox",
      "id": "open_new_tab",
      "label": "Open link in new tab",
      "default": false
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Ad banner",
      "category": "Banners"
    }
  ]
}
{% endschema %}
