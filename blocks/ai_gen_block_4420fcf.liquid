{% doc %}
  @prompt
    a responsive banner image announcement bar for mobile and desktop with clickable 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-banner-announcement-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .ai-banner-announcement-link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }

  .ai-banner-announcement-link-{{ ai_gen_id }}:hover {
    opacity: {{ block.settings.hover_opacity | divided_by: 100.0 }};
  }

  .ai-banner-announcement-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .ai-banner-announcement-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-banner-announcement-desktop-{{ ai_gen_id }} {
    display: none;
  }

  .ai-banner-announcement-mobile-{{ ai_gen_id }} {
    display: block;
  }

  .ai-banner-announcement-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-height: 80px;
  }

  .ai-banner-announcement-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 120px;
  }

  .ai-banner-announcement-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 12px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (min-width: 750px) {
    .ai-banner-announcement-desktop-{{ ai_gen_id }} {
      display: block;
    }

    .ai-banner-announcement-mobile-{{ ai_gen_id }} {
      display: none;
    }

    .ai-banner-announcement-placeholder-{{ ai_gen_id }} {
      min-height: 120px;
    }
  }
{% endstyle %}

<banner-announcement-{{ ai_gen_id }}
  class="ai-banner-announcement-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.link_url != blank %}
    <a
      href="{{ block.settings.link_url }}"
      class="ai-banner-announcement-link-{{ ai_gen_id }}"
      {% if block.settings.open_in_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
    >
  {% else %}
    <div class="ai-banner-announcement-link-{{ ai_gen_id }}">
  {% endif %}

    <div class="ai-banner-announcement-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.desktop_image != blank %}
        <div class="ai-banner-announcement-desktop-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.desktop_image | image_url: width: 2000 }}"
            alt="{{ block.settings.desktop_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.desktop_image.width }}"
            height="{{ block.settings.desktop_image.height }}"
            class="ai-banner-announcement-image-{{ ai_gen_id }}"
          >
        </div>
      {% else %}
        <div class="ai-banner-announcement-desktop-{{ ai_gen_id }}">
          <div class="ai-banner-announcement-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-banner-announcement-empty-state-{{ ai_gen_id }}">
              Add a desktop banner image
            </div>
          </div>
        </div>
      {% endif %}

      {% if block.settings.mobile_image != blank %}
        <div class="ai-banner-announcement-mobile-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.mobile_image | image_url: width: 800 }}"
            alt="{{ block.settings.mobile_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.mobile_image.width }}"
            height="{{ block.settings.mobile_image.height }}"
            class="ai-banner-announcement-image-{{ ai_gen_id }}"
          >
        </div>
      {% else %}
        <div class="ai-banner-announcement-mobile-{{ ai_gen_id }}">
          <div class="ai-banner-announcement-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-banner-announcement-empty-state-{{ ai_gen_id }}">
              Add a mobile banner image
            </div>
          </div>
        </div>
      {% endif %}
    </div>

  {% if block.settings.link_url != blank %}
    </a>
  {% else %}
    </div>
  {% endif %}
</banner-announcement-{{ ai_gen_id }}>

<script>
  (function() {
    class BannerAnnouncement{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('banner-announcement-{{ ai_gen_id }}', BannerAnnouncement{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Banner announcement",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop banner image"
    },
    {
      "type": "header",
      "content": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile banner image"
    },
    {
      "type": "header",
      "content": "Link settings"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Banner link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "Open link in new tab",
      "default": false
    },
    {
      "type": "header",
      "content": "Hover effect"
    },
    {
      "type": "range",
      "id": "hover_opacity",
      "label": "Hover opacity",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 85
    }
  ],
  "presets": [
    {
      "name": "Banner announcement"
    }
  ]
}
{% endschema %}
