{% doc %}
  @prompt
    need prepositions grid with icon and text 4 on desktop 1 on phone carousel in phone smooth slider, hmm small icon and single line text no heading needed, it should be horizontal inline and phone  center text, also icon and text inline on phone as well and center text one preposition on time, on phone i see the second preposition as well only 1 at a time no hint
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-propositions-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    display: block;
    padding-top:0;
    margin-top:-15px;
  }

  .ai-propositions-container-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.gap }}px {{ block.settings.horizontal_gap }}px;
    width: 100%;
  }

  .ai-proposition-item-{{ ai_gen_id }} {
    display: inline-flex;
    flex-direction: row;
    align-items: center;
    gap: {{ block.settings.item_gap }}px;
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-proposition-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
  }

  .ai-proposition-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-proposition-icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_placeholder_bg }};
    border-radius: 50%;
  }

  .ai-proposition-icon-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-proposition-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.4;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .ai-propositions-container-{{ ai_gen_id }} {
      display: block;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .ai-propositions-container-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-propositions-inner-{{ ai_gen_id }} {
      display: flex;
      gap: {{ block.settings.gap }}px;
      padding: 0 16px;
    }

    .ai-proposition-item-{{ ai_gen_id }} {
      min-width: 100%;
      width: 100%;
      scroll-snap-align: center;
      flex-shrink: 0;
      justify-content: center;
    }

    .ai-proposition-text-{{ ai_gen_id }} {
      white-space: normal;
      text-align: center;
    }
  }
{% endstyle %}

<propositions-grid-{{ ai_gen_id }}
  class="ai-propositions-{{ ai_gen_id }}"
  data-mobile-autoplay="{{ block.settings.mobile_autoplay }}"
  data-mobile-autoplay-interval="{{ block.settings.mobile_autoplay_interval | default: 4 }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-propositions-container-{{ ai_gen_id }}">
    <div class="ai-propositions-inner-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign icon_key = 'icon_' | append: i
          assign text_key = 'text_' | append: i
          
          assign icon = block.settings[icon_key]
          assign text = block.settings[text_key]
        %}
        
        <div class="ai-proposition-item-{{ ai_gen_id }}">
          <div class="ai-proposition-icon-{{ ai_gen_id }}">
            {% if icon %}
              <img
                src="{{ icon | image_url: width: 100 }}"
                alt="{{ text | escape }}"
                loading="lazy"
                width="100"
                height="100"
              >
            {% else %}
              <div class="ai-proposition-icon-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          
          {% if text != blank %}
            <p class="ai-proposition-text-{{ ai_gen_id }}">{{ text }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</propositions-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class PropositionsGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this._autoplayTimer = null;
        this._resumeTimer = null;
        this._isUserInteracting = false;
        this._isVisible = false;
        this._mql = null;
      }

      connectedCallback() {
        this.container = this.querySelector('.ai-propositions-container-{{ ai_gen_id }}');
        if (!this.container) return;

        this.items = this.querySelectorAll('.ai-proposition-item-{{ ai_gen_id }}');
        this._mql = window.matchMedia('(max-width: 749px)');

        this.setupMobileDrag();
        this.setupAutoplay();

        // Re-evaluate on viewport change.
        this._mql.addEventListener('change', this._onMediaChange);
        window.addEventListener('resize', this._onResize);
      }

      disconnectedCallback() {
        this.stopAutoplay();
        if (this._observer) this._observer.disconnect();
        if (this._mql) this._mql.removeEventListener('change', this._onMediaChange);
        window.removeEventListener('resize', this._onResize);
      }

      _onMediaChange = () => {
        this.stopAutoplay();
        this.setupAutoplay();
      };

      _onResize = () => {
        // Container width can change on rotation; recompute on next interval.
      };

      setupMobileDrag() {
        const container = this.container;
        if (!this._mql.matches) return;

        let isDown = false;
        let startX;
        let scrollLeft;

        container.addEventListener('mousedown', (e) => {
          isDown = true;
          startX = e.pageX - container.offsetLeft;
          scrollLeft = container.scrollLeft;
          this.pauseAutoplayForInteraction();
        });

        container.addEventListener('mouseleave', () => {
          isDown = false;
        });

        container.addEventListener('mouseup', () => {
          isDown = false;
        });

        container.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - container.offsetLeft;
          const walk = (x - startX) * 2;
          container.scrollLeft = scrollLeft - walk;
        });

        // Touch / native scroll also pauses autoplay.
        container.addEventListener('touchstart', this.pauseAutoplayForInteraction, { passive: true });
        container.addEventListener('scroll', this._onUserScroll, { passive: true });
      }

      _onUserScroll = () => {
        // Only treat as "user" scrolling if not currently animating ourselves.
        if (this._isProgrammaticScroll) return;
        this.pauseAutoplayForInteraction();
      };

      setupAutoplay() {
        const enabled = this.dataset.mobileAutoplay === 'true';
        if (!enabled) return;
        if (!this._mql.matches) return;
        if (!this.items || this.items.length < 2) return;

        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reducedMotion) return;

        // Only run when the section is actually visible to save battery.
        if (!this._observer) {
          this._observer = new IntersectionObserver((entries) => {
            for (const entry of entries) {
              this._isVisible = entry.isIntersecting;
              if (this._isVisible && !this._isUserInteracting) {
                this.startAutoplay();
              } else {
                this.stopAutoplay();
              }
            }
          }, { threshold: 0.4 });
          this._observer.observe(this);
        } else if (this._isVisible) {
          this.startAutoplay();
        }
      }

      startAutoplay() {
        this.stopAutoplay();
        const intervalSec = parseFloat(this.dataset.mobileAutoplayInterval || '4');
        const intervalMs = Math.max(1500, intervalSec * 1000);
        this._autoplayTimer = window.setInterval(() => this.advance(), intervalMs);
      }

      stopAutoplay() {
        if (this._autoplayTimer) {
          clearInterval(this._autoplayTimer);
          this._autoplayTimer = null;
        }
      }

      pauseAutoplayForInteraction = () => {
        this._isUserInteracting = true;
        this.stopAutoplay();
        if (this._resumeTimer) clearTimeout(this._resumeTimer);
        this._resumeTimer = window.setTimeout(() => {
          this._isUserInteracting = false;
          if (this._isVisible) this.setupAutoplay();
        }, 6000);
      };

      advance() {
        const container = this.container;
        if (!container || !this.items || this.items.length === 0) return;

        const itemWidth = this.items[0].getBoundingClientRect().width;
        if (itemWidth === 0) return;

        const styles = window.getComputedStyle(container.querySelector('.ai-propositions-inner-{{ ai_gen_id }}') || container);
        const gap = parseFloat(styles.gap || styles.columnGap || '0') || 0;
        const step = itemWidth + gap;

        const maxScroll = container.scrollWidth - container.clientWidth;
        let nextScroll = container.scrollLeft + step;
        if (nextScroll > maxScroll - 4) nextScroll = 0;

        this._isProgrammaticScroll = true;
        container.scrollTo({ left: nextScroll, behavior: 'smooth' });
        // Release the programmatic flag after the smooth scroll settles.
        window.setTimeout(() => { this._isProgrammaticScroll = false; }, 700);
      }
    }

    customElements.define('propositions-grid-{{ ai_gen_id }}', PropositionsGrid{{ ai_gen_id }});
  })();
</script>

