{% doc %}
  @prompt
    image thumbnails section in slider 5 on desktop 3 on mobile devices , buttons are optional 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-slider-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-image-slider-container-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-image-slider-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    transition: transform 0.3s ease;
    will-change: transform;
  }

  .ai-image-slider-item-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.desktop_columns | minus: 1 }} * {{ block.settings.gap }}px)) / {{ block.settings.desktop_columns }});
    cursor: pointer;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .ai-image-slider-item-{{ ai_gen_id }}:hover {
    opacity: 0.8;
    transform: scale(1.05);
  }

  .ai-image-slider-item-{{ ai_gen_id }}.active {
    outline: {{ block.settings.active_border_width }}px solid {{ block.settings.active_border_color }};
    outline-offset: -{{ block.settings.active_border_width }}px;
  }

  .ai-image-slider-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.thumbnail_height }}px;
    object-fit: cover;
    display: block;
  }

  .ai-image-slider-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.thumbnail_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-slider-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-image-slider-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_button_bg }};
    color: {{ block.settings.nav_button_color }};
    border: none;
    width: {{ block.settings.nav_button_size }}px;
    height: {{ block.settings.nav_button_size }}px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: background-color 0.3s ease, opacity 0.3s ease;
    opacity: 0.9;
  }

  {% if block.settings.show_nav_buttons == false %}
    .ai-image-slider-nav-{{ ai_gen_id }} {
      display: none;
    }
  {% endif %}

  .ai-image-slider-nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_bg }};
    opacity: 1;
  }

  .ai-image-slider-nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-image-slider-nav-{{ ai_gen_id }}.prev {
    left: {{ block.settings.nav_button_offset }}px;
  }

  .ai-image-slider-nav-{{ ai_gen_id }}.next {
    right: {{ block.settings.nav_button_offset }}px;
  }

  .ai-image-slider-nav-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-image-slider-item-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.mobile_columns | minus: 1 }} * {{ block.settings.gap }}px)) / {{ block.settings.mobile_columns }});
    }

    .ai-image-slider-nav-{{ ai_gen_id }} {
      width: {{ block.settings.nav_button_size | times: 0.8 }}px;
      height: {{ block.settings.nav_button_size | times: 0.8 }}px;
    }

    .ai-image-slider-nav-{{ ai_gen_id }}.prev {
      left: {{ block.settings.nav_button_offset | times: 0.5 }}px;
    }

    .ai-image-slider-nav-{{ ai_gen_id }}.next {
      right: {{ block.settings.nav_button_offset | times: 0.5 }}px;
    }
  }
{% endstyle %}

<image-slider-{{ ai_gen_id }} class="ai-image-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-slider-container-{{ ai_gen_id }}">
    <button
      class="ai-image-slider-nav-{{ ai_gen_id }} prev"
      aria-label="Previous images"
      data-direction="prev"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <div class="ai-image-slider-track-{{ ai_gen_id }}">
      {% for i in (1..10) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign image = block.settings[image_key]
        %}
        
        {% if image != blank %}
          <div class="ai-image-slider-item-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}" data-index="{{ forloop.index0 }}">
            <img
              src="{{ image | image_url: width: 400 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="400"
              height="{{ block.settings.thumbnail_height }}"
              class="ai-image-slider-image-{{ ai_gen_id }}"
            >
          </div>
        {% else %}
          <div class="ai-image-slider-item-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}" data-index="{{ forloop.index0 }}">
            <div class="ai-image-slider-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <button
      class="ai-image-slider-nav-{{ ai_gen_id }} next"
      aria-label="Next images"
      data-direction="next"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
</image-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.itemsPerView = {{ block.settings.desktop_columns }};
        this.gap = {{ block.settings.gap }};
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-image-slider-track-{{ ai_gen_id }}');
        this.items = this.querySelectorAll('.ai-image-slider-item-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-image-slider-nav-{{ ai_gen_id }}.prev');
        this.nextButton = this.querySelector('.ai-image-slider-nav-{{ ai_gen_id }}.next');
        
        this.updateItemsPerView();
        this.setupEventListeners();
        this.updateButtons();
      }

      updateItemsPerView() {
        if (window.innerWidth <= 749) {
          this.itemsPerView = {{ block.settings.mobile_columns }};
        } else {
          this.itemsPerView = {{ block.settings.desktop_columns }};
        }
      }

      setupEventListeners() {
        if (this.prevButton && this.nextButton) {
          this.prevButton.addEventListener('click', () => this.navigate('prev'));
          this.nextButton.addEventListener('click', () => this.navigate('next'));
        }

        this.items.forEach((item, index) => {
          item.addEventListener('click', () => this.selectItem(index));
        });

        window.addEventListener('resize', () => {
          this.updateItemsPerView();
          this.updateSlider();
        });
      }

      navigate(direction) {
        if (direction === 'prev' && this.currentIndex > 0) {
          this.currentIndex--;
        } else if (direction === 'next' && this.currentIndex < this.items.length - this.itemsPerView) {
          this.currentIndex++;
        }
        this.updateSlider();
      }

      selectItem(index) {
        this.items.forEach((item) => item.classList.remove('active'));
        this.items[index].classList.add('active');

        if (index < this.currentIndex) {
          this.currentIndex = index;
        } else if (index >= this.currentIndex + this.itemsPerView) {
          this.currentIndex = index - this.itemsPerView + 1;
        }

        this.updateSlider();
      }

      updateSlider() {
        const itemWidth = this.items[0].offsetWidth;
        const offset = -(this.currentIndex * (itemWidth + this.gap));
        this.track.style.transform = 'translateX(' + offset + 'px)';
        this.updateButtons();
      }

      updateButtons() {
        if (this.prevButton && this.nextButton) {
          this.prevButton.disabled = this.currentIndex === 0;
          this.nextButton.disabled = this.currentIndex >= this.items.length - this.itemsPerView;
        }
      }
    }

    customElements.define('image-slider-{{ ai_gen_id }}', ImageSlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Image thumbnails slider",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "Thumbnails on desktop",
      "min": 3,
      "max": 8,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "mobile_columns",
      "label": "Thumbnails on mobile",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between thumbnails",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Thumbnail style"
    },
    {
      "type": "range",
      "id": "thumbnail_height",
      "label": "Thumbnail height",
      "min": 60,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "active_border_width",
      "label": "Active border width",
      "min": 1,
      "max": 6,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "color",
      "id": "active_border_color",
      "label": "Active border color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Navigation buttons"
    },
    {
      "type": "checkbox",
      "id": "show_nav_buttons",
      "label": "Show navigation buttons",
      "default": true
    },
    {
