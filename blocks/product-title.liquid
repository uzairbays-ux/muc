

{%- liquid
  assign custom_desktop_class = block.settings.custom_class_desktop | strip
  assign custom_mobile_class  = block.settings.custom_class_mobile  | strip
  assign extra_classes = custom_desktop_class
  if custom_mobile_class != blank
    assign extra_classes = extra_classes | append: ' ' | append: custom_mobile_class
  endif
-%}

{% if closest.product == blank %}
  {% assign text = 'placeholders.product_title' | t %}
  {% assign product_title = '<p role="heading" aria-level="3">' | append: text | append: '</p>' %}
  {% render 'text', fallback_text: product_title, block: block, class: extra_classes %}
{% else %}
  {% assign product_title = '<p role="heading" aria-level="3">' | append: closest.product.title | append: '</p>' %}
  <a
    class="contents user-select-text"
    ref="productTitleLink"
    href="{{ closest.product.selected_or_first_available_variant.url }}"
  >
    {% render 'text', fallback_text: product_title, block: block, class: extra_classes %}
  </a>
{% endif %}


{%- liquid
  assign mt = block.settings
  assign has_mobile_overrides = false
  if mt.type_preset == 'custom'
    if mt.mobile_font_size != blank or mt.mobile_font != blank or mt.mobile_line_height != blank or mt.mobile_letter_spacing != blank or mt.mobile_case != blank or mt.mobile_weight != blank
      assign has_mobile_overrides = true
    endif
  endif

  assign mobile_lh = ''
  case mt.mobile_line_height
    when 'tight'
      assign mobile_lh = '1.2'
    when 'normal'
      assign mobile_lh = '1.4'
    when 'loose'
      assign mobile_lh = '1.6'
  endcase

  assign mobile_ls = ''
  case mt.mobile_letter_spacing
    when 'tight'
      assign mobile_ls = '-0.03em'
    when 'normal'
      assign mobile_ls = '0em'
    when 'loose'
      assign mobile_ls = '0.03em'
  endcase
-%}

{%- if has_mobile_overrides -%}
  <style>
    @media (max-width: 749px) {
      .text-block--{{ block.id }},
      .text-block--{{ block.id }} > * {
        {%- if mt.mobile_font_size != blank %} font-size: {{ mt.mobile_font_size }} !important;{% endif -%}
        {%- if mt.mobile_font != blank %} font-family: {{ mt.mobile_font }} !important;{% endif -%}
        {%- if mt.mobile_weight != blank %} font-weight: {{ mt.mobile_weight }} !important;{% elsif mt.mobile_font != blank %} font-weight: {{ mt.mobile_font | replace: 'family', 'weight' }} !important;{% endif -%}
        {%- if mobile_lh != '' %} line-height: {{ mobile_lh }} !important;{% endif -%}
        {%- if mobile_ls != '' %} letter-spacing: {{ mobile_ls }} !important;{% endif -%}
        {%- if mt.mobile_case != blank %} text-transform: {{ mt.mobile_case }} !important;{% endif -%}
      }
    }
  </style>
{%- endif -%}

