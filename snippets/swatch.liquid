{%- doc -%}
  Renders a swatch either from a variant image object or a swatch object.

  @param {object} swatch - a swatch object
  @param {object} [variant_image] - an alternate image when there is no swatch value
  @param {string} [mode] - one of 'unscaled', 'filter', 'pill'
  @param {string} [label] - visually-hidden accessible label for the swatch (e.g. the color name)

  @example
  {% render 'swatch', swatch: swatch, variant_image: variant_image, mode: 'unscaled', label: option_value.name %}
{%- enddoc -%}

{% liquid
  assign swatch_value = null
  assign extra_classes = ''

  # --- Step 1: Check custom color definitions first (highest priority) ---
  # This must run before variant_image so that named colors always win over
  # product photos being used as swatch backgrounds.
  assign mapped_color = null
  if label != blank and settings.swatch_color_definitions != blank
    assign label_lower = label | downcase | strip
    assign color_lines = settings.swatch_color_definitions | newline_to_br | split: '<br />'
    for color_line in color_lines
      assign trimmed_line = color_line | strip
      if trimmed_line != blank and mapped_color == null
        assign line_parts = trimmed_line | split: ':'
        if line_parts.size >= 2
          assign def_name = line_parts[0] | downcase | strip
          if def_name == label_lower
            assign mapped_color = line_parts[1] | strip
          endif
        endif
      endif
    endfor
  endif

  if mapped_color != null
    # Custom color definition wins.
    # Value may be: "#hex", "url(...) #hex" (image + color fallback), or just "url(...)"
    # CSS handles image+fallback natively: background: url(...) #hex
    assign swatch_value = mapped_color
    if mapped_color contains 'url('
      assign extra_classes = extra_classes | append: ' swatch--variant-image'
    endif

  elsif swatch.image
    # Explicit swatch image from Shopify metafield
    assign swatch_image_url = swatch.image | image_url: width: 80
    assign swatch_value = 'url(' | append: swatch_image_url | append: ')'

  elsif swatch.color
    # Native Shopify color metafield
    assign swatch_value = 'rgb(' | append: swatch.color.rgb | append: ')'

  elsif settings.show_variant_image and variant_image
    # Fallback: variant product photo (only when no color is defined)
    assign swatch_image_width = settings.variant_swatch_width | times: 2
    assign swatch_image_url = variant_image | image_url: width: swatch_image_width
    assign swatch_value = 'url(' | append: swatch_image_url | append: ')'
    assign extra_classes = extra_classes | append: ' swatch--variant-image'

  elsif label != blank
    # Last resort: CSS color name derived from label text
    assign swatch_value = label | downcase | replace: ' ', ''
    assign extra_classes = extra_classes | append: ' swatch--named-color'
  endif

  case mode
    when 'unscaled'
      assign extra_classes = extra_classes | append: ' swatch--unscaled'
    when 'filter'
      assign extra_classes = extra_classes | append: ' swatch--filter'
    when 'pill'
      assign extra_classes = extra_classes | append: ' swatch--pill'
  endcase
%}

<span
  class="
    swatch
    {{ extra_classes }}
    {% if swatch_value == null %} swatch--unavailable{% endif %}
  "
  style="
    --swatch-background: {{ swatch_value }};
    {% if swatch.image and settings.show_variant_image == false %} --swatch-focal-point: {{ swatch.image.presentation.focal_point }};{% endif %}
  "
>
</span>
{%- if label != blank -%}
  <span class="visually-hidden">{{ label }}</span>
{%- endif -%}
